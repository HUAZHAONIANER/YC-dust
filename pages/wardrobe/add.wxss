.add-container {
  background: linear-gradient(135deg, #f5f0ff 0%, #e9e0ff 100%);
  min-height: 100vh;
}

/* 导航头部 */
.nav-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 40rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10px);
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-back {
  color: #9b5de5;
  font-size: 32rpx;
  font-weight: bold;
}

.nav-title {
  color: #333;
  font-size: 36rpx;
  font-weight: bold;
}

.nav-placeholder {
  width: 120rpx;
}

.form-card {
  background: white;
  border-radius: 30rpx 30rpx 0 0;
  padding: 40rpx;
  margin-top: 20rpx;
  min-height: calc(100vh - 120rpx);
}

.form-group {
  margin-bottom: 40rpx;
}

.form-label {
  display: block;
  color: #333;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.form-input, .category-picker, .date-picker {
  width: 100%;
  padding: 25rpx 0;
  border-bottom: 3rpx solid #f0f0f0;
  font-size: 32rpx;
  color: #333;
  transition: border-color 0.3s ease;
}

.form-input:focus, .category-picker:focus, .date-picker:focus {
  border-bottom-color: #9b5de5;
}

.picker-text {
  color: #999;
  font-size: 32rpx;
  padding: 10rpx 0;
}

.picker-text.has-value {
  color: #333;
}

.note-input {
  width: 100%;
  height: 200rpx;
  padding: 25rpx;
  border: 3rpx solid #f0f0f0;
  border-radius: 20rpx;
  font-size: 28rpx;
  background: #fafafa;
  box-sizing: border-box;
}

.upload-section {
  margin-top: 10rpx;
}

.upload-area {
  width: 100%;
  height: 300rpx;
  border: 3rpx dashed #ddd;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fafafa;
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.upload-area:active {
  background: #f5f5f5;
  transform: scale(0.98);
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  font-size: 80rpx;
  color: #ccc;
  margin-bottom: 20rpx;
}

.upload-text {
  color: #999;
  font-size: 28rpx;
}

.preview-image {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
}

.upload-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.upload-area:hover .upload-overlay {
  opacity: 1;
}

.upload-change {
  color: white;
  font-size: 28rpx;
  font-weight: bold;
}

.save-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #9b5de5, #7b3de0);
  color: white;
  border-radius: 50rpx;
  font-size: 36rpx;
  font-weight: bold;
  margin-top: 60rpx;
  border: none;
  transition: all 0.3s ease;
  box-shadow: 0 10rpx 30rpx rgba(155, 93, 229, 0.3);
}

.btn-hover {
  opacity: 0.9;
  transform: translateY(-2rpx);
  box-shadow: 0 15rpx 40rpx rgba(155, 93, 229, 0.4);
}