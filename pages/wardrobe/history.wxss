.history-container {
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  min-height: 100vh;
}

/* 页面头部 */
.page-header {
  padding: 40rpx 40rpx 20rpx;
  background: white;
  border-radius: 0 0 30rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
}

.page-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.page-subtitle {
  display: block;
  font-size: 28rpx;
  color: #666;
}

/* 搜索和筛选 */
.search-filter-bar {
  padding: 30rpx 40rpx 20rpx;
}

.search-box {
  position: relative;
}

.search-input {
  height: 80rpx;
  padding: 0 80rpx 0 30rpx;
  background: white;
  border-radius: 40rpx;
  font-size: 28rpx;
  box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.1);
}

.search-clear {
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  color: #999;
  font-size: 32rpx;
}

/* 筛选容器 */
.filter-container {
  padding: 0 40rpx 20rpx;
}

.filter-row {
  display: flex;
  gap: 20rpx;
}

.filter-picker {
  flex: 1;
}

.filter-btn {
  height: 80rpx;
  padding: 0 30rpx;
  background: white;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #666;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.1);
  white-space: nowrap;
}

/* 统计信息 */
.stats-section {
  background: white;
  margin: 0 40rpx 30rpx;
  padding: 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.1);
}

.stats-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.stats-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.stats-count {
  font-size: 28rpx;
  color: #9b5de5;
  font-weight: bold;
}

.stats-category {
  margin-bottom: 30rpx;
}

.stats-category:last-child {
  margin-bottom: 0;
}

.stats-subtitle {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 20rpx;
  font-weight: bold;
}

.category-tags, .color-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.category-tag, .color-tag {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 15rpx 20rpx;
  background: #f5f0ff;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #333;
}

.color-tag {
  color: white;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.2);
}

.tag-name {
  font-weight: bold;
}

.tag-count {
  background: white;
  color: #9b5de5;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
  font-size: 22rpx;
  font-weight: bold;
}

.color-tag .tag-count {
  background: rgba(255, 255, 255, 0.9);
  color: #333;
}

/* 衣物列表 */
.clothes-list {
  width: 680rpx;
  height: calc(100vh - 400rpx);
  padding: 0 40rpx 40rpx;
}

.clothing-card {
  background: white;
  border-radius: 25rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.1);
  overflow: hidden;
  transition: all 0.3s ease;
}

.clothing-card:active {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 40rpx rgba(0,0,0,0.15);
}

/* 衣物图片 */
.clothing-image-section {
  position: relative;
  height: 300rpx;
  background: #f8f9fa;
}

.clothing-image {
  width: 100%;
  height: 100%;
}

.default-image {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f5f0ff, #e9e0ff);
}

.default-icon {
  font-size: 100rpx;
  color: #9b5de5;
}

.image-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(to bottom, transparent 60%, rgba(0,0,0,0.3));
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding: 20rpx;
}

.category-tag, .season-tag {
  color: white;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: bold;
  background: rgba(155, 93, 229, 0.9);
}

.season-tag {
  background: rgba(77, 150, 255, 0.9);
}

/* 衣物内容 */
.clothing-content {
  padding: 40rpx;
}

.clothing-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.brand-info {
  flex: 1;
}

.brand {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.color {
  display: block;
  font-size: 26rpx;
  font-weight: bold;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  background: #f8f9fa;
  display: inline-block;
}

.purchase-date {
  font-size: 26rpx;
  color: #666;
}

/* 衣物详情 */
.clothing-details {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 25rpx;
  padding: 25rpx;
  background: #f8f9fa;
  border-radius: 15rpx;
}

.detail-item {
  display: flex;
  flex-direction: column;
}

.detail-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.detail-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 备注 */
.note-section {
  margin-bottom: 25rpx;
  padding: 25rpx;
  background: #f0f4ff;
  border-radius: 15rpx;
  border-left: 6rpx solid #4d96ff;
}

.note-label {
  display: block;
  color: #666;
  font-size: 24rpx;
  margin-bottom: 10rpx;
  font-weight: bold;
}

.note-content {
  color: #666;
  font-size: 28rpx;
  line-height: 1.5;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.edit-btn, .delete-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  transition: all 0.3s ease;
}

.edit-btn {
  background: linear-gradient(135deg, #74c0fc, #4dabf7);
  color: white;
}

.delete-btn {
  background: linear-gradient(135deg, #ff8787, #ff6b6b);
  color: white;
}

.edit-btn:active, .delete-btn:active {
  transform: scale(0.95);
  opacity: 0.8;
}

.btn-icon {
  font-size: 32rpx;
}

.btn-text {
  font-size: 28rpx;
}

/* 时间信息 */
.time-info {
  display: flex;
  justify-content: space-between;
  border-top: 1rpx solid #e9ecef;
  padding-top: 20rpx;
}

.time-text {
  font-size: 22rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 40rpx;
  background: white;
  border-radius: 25rpx;
  margin-top: 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 30rpx;
}

.empty-title {
  display: block;
  font-size: 36rpx;
  color: #333;
  margin-bottom: 20rpx;
  font-weight: bold;
}

.empty-desc {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 50rpx;
}

.empty-btn {
  display: inline-block;
  padding: 25rpx 50rpx;
  background: linear-gradient(135deg, #9b5de5, #7b3de0);
  color: white;
  border-radius: 35rpx;
  font-size: 30rpx;
  box-shadow: 0 8rpx 25rpx rgba(155, 93, 229, 0.3);
}

/* 悬浮按钮 */
.fab-container {
  position: fixed;
  bottom: 60rpx;
  right: 40rpx;
  z-index: 1000;
}

.fab-btn {
  height: 80rpx;
  background: linear-gradient(135deg, #9b5de5, #7b3de0);
  border-radius: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 30rpx rgba(155, 93, 229, 0.4);
  transition: all 0.3s ease;
}

.fab-btn:active {
  transform: scale(0.9);
  box-shadow: 0 15rpx 40rpx rgba(155, 93, 229, 0.6);
}

.fab-icon {
  color: white;
  font-size: 50rpx;
  font-weight: bold;
}