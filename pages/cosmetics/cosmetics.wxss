.cosmetics-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #fff0f5 0%, #ffe4e9 100%);
  padding: 30rpx;
}

/* 头部区域 */
.header-section {
  text-align: center;
  margin-bottom: 50rpx;
  padding: 20rpx 0;
}

.welcome-text {
  font-size: 38rpx;
  color: #ff69b4;
  transition: opacity 0.6s ease;
  text-shadow: 0 4rpx 8rpx rgba(255, 105, 180, 0.3);
  font-weight: bold;
  display: block;
  margin-bottom: 15rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #888;
  display: block;
}

/* 功能卡片 */
.function-cards {
  margin-bottom: 50rpx;
}

.function-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 25rpx;
  padding: 35rpx 30rpx;
  margin-bottom: 25rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 30rpx rgba(255, 182, 193, 0.3);
  transition: all 0.3s ease;
  border-left: 8rpx solid transparent;
}

.function-card:active {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 40rpx rgba(255, 182, 193, 0.4);
}

.pink-card {
  border-left-color: #ff69b4;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.95), rgba(255, 240, 245, 0.9));
}

.purple-card {
  border-left-color: #c792ea;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.95), rgba(245, 240, 255, 0.9));
}

.coral-card {
  border-left-color: #ff8c94;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.95), rgba(255, 240, 242, 0.9));
}

.card-icon {
  font-size: 56rpx;
  margin-right: 25rpx;
  width: 70rpx;
  text-align: center;
}

.card-content {
  flex: 1;
}

.card-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.card-desc {
  display: block;
  font-size: 24rpx;
  color: #888;
}

.card-arrow {
  font-size: 40rpx;
  color: #ccc;
  font-weight: bold;
}

/* 统计区域 */
.stats-section {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 25rpx;
  padding: 35rpx 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(255, 182, 193, 0.2);
  margin-bottom: 30rpx;
}

.stats-header {
  margin-bottom: 30rpx;
}

.stats-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
}

.stats-grid {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-number {
  font-size: 42rpx;
  font-weight: bold;
  color: #ff69b4;
  margin-bottom: 10rpx;
  transition: color 0.3s ease;
}

.stat-number.warning {
  color: #ff6b6b;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0% { transform: scale(1); }
  50% { transform: scale(1.1); }
  100% { transform: scale(1); }
}

.stat-label {
  font-size: 24rpx;
  color: #666;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 25rpx;
  margin-top: 40rpx;
  box-shadow: 0 8rpx 30rpx rgba(255, 182, 193, 0.2);
}

.empty-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 30rpx;
}

.empty-title {
  display: block;
  font-size: 36rpx;
  color: #333;
  margin-bottom: 20rpx;
  font-weight: bold;
}

.empty-desc {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 50rpx;
}

.empty-btn {
  display: inline-block;
  padding: 25rpx 50rpx;
  background: linear-gradient(135deg, #ff9ecb, #ff69b4);
  color: white;
  border-radius: 35rpx;
  font-size: 30rpx;
  box-shadow: 0 8rpx 25rpx rgba(255, 105, 180, 0.3);
  border: none;
}

.empty-btn:active {
  transform: scale(0.98);
}